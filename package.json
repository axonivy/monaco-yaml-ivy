{
  "name": "@axonviy/monaco-yaml-ivy",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "24.14.1"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "serve": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "sbom": "pnpm sbom --sbom-format cyclonedx --prod > bom.json",
    "sbom:dev": "pnpm sbom --sbom-format cyclonedx > bom-dev.json"
  },
  "dependencies": {
    "monaco-languageserver-types": "^0.4.0",
    "monaco-editor": "0.54.0",
    "monaco-yaml": "^5.2.3"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0",
    "vite": "8.0.10"
  }
}
